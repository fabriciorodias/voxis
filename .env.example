# Supabase — projeto onde o schema do Voxis foi criado
# Obtenha em https://supabase.com/dashboard/project/<seu-projeto>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — obrigatório apenas para o CRUD de usuários
# (/admin/usuarios) e reset de senha. Bypassa RLS; NÃO expor no front.
# Obtenha em Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# URL pública da instância (usada para gerar o link dos QR Codes dos GRs)
# Opcional no Vercel: se omitido, usa VERCEL_PROJECT_PRODUCTION_URL automaticamente.
# Em produção com domínio customizado, colocar HTTPS real:
#   NEXT_PUBLIC_APP_URL=https://voxis.seubanco.com.br
NEXT_PUBLIC_APP_URL=http://localhost:3000
